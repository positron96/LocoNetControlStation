/**
 * @file rmt_continuous_tx_example.cpp
 * @brief Example: continuous (gapless) RMT TX streaming on ESP32 using LL API
 *
 * This demonstrates a ping-pong double-buffer approach:
 *  - Channel uses N memory blocks (e.g. 4 blocks = 256 items)
 *  - tx_conti_mode wraps the read pointer back to start automatically
 *  - TX_THRES interrupt fires at the halfway point → refill first half
 *  - TX_DONE interrupt fires at the end → refill second half
 *  - Firmware writes new data into the "consumed" half while HW reads the other
 *
 * The result is seamless, gap-free output — suitable for DCC, WS2812 streams, etc.
 *
 * Hardware: ESP32 (original), uses RMT channel 0 with 4 memory blocks (256 items).
 * This means channels 1-3 are consumed by channel 0's extended memory.
 *
 * NOTE: This is an EXAMPLE / reference implementation, not a compilable library.
 *       Adapt the ISR callback and buffer-fill logic to your application.
 */

#include <cstring>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "soc/rmt_struct.h"
#include "soc/rmt_reg.h"
#include "soc/rmt_periph.h"
#include "hal/rmt_ll.h"
#include "hal/gpio_hal.h"
#include "esp_intr_alloc.h"
#include "esp_rom_gpio.h"
#include "driver/gpio.h"
#include "esp_log.h"

static const char *TAG = "rmt_cont_tx";

// ─── Configuration ───────────────────────────────────────────────────────────

#define RMT_TX_CHANNEL       0          // Use channel 0
#define RMT_TX_GPIO          GPIO_NUM_4 // Output pin
#define RMT_CLK_DIV          1          // Clock divider (1 = 80 MHz tick @ APB)
#define RMT_MEM_BLOCKS       4          // 4 blocks × 64 items = 256 items total
#define RMT_ITEMS_PER_BLOCK  64
#define RMT_TOTAL_ITEMS      (RMT_MEM_BLOCKS * RMT_ITEMS_PER_BLOCK)  // 256
#define RMT_HALF_ITEMS       (RMT_TOTAL_ITEMS / 2)                    // 128

// ─── State ───────────────────────────────────────────────────────────────────

static intr_handle_t s_intr_handle = nullptr;

// Pointer to the RMT channel memory (hardware RAM, memory-mapped)
static volatile rmt_item32_t *rmt_mem_ptr() {
    // RMT memory base for channel 0: 0x3FF56800
    // Each channel offset = channel * 64 items * 4 bytes
    return reinterpret_cast<volatile rmt_item32_t *>(RMT_CHANNEL_MEM(RMT_TX_CHANNEL));
}

// ─── Application callback: fill items into the buffer ────────────────────────
// Replace this with your actual waveform generation (DCC packets, LED data, etc.)

/**
 * @brief Fill RMT items into the given region of hardware memory.
 *
 * @param offset  Item offset within the channel's memory (0..RMT_TOTAL_ITEMS-1)
 * @param count   Number of items to fill
 *
 * Called from ISR context — keep it fast!
 */
static void IRAM_ATTR fill_rmt_items(uint16_t offset, uint16_t count) {
    volatile rmt_item32_t *mem = rmt_mem_ptr();

    // Example: generate a simple square wave (58µs high + 58µs low per item)
    // In a real application, encode your DCC packet bits here.
    for (uint16_t i = 0; i < count; i++) {
        mem[offset + i].level0 = 1;
        mem[offset + i].duration0 = 58;  // 58 ticks @ 1 MHz = 58µs (DCC '1' half)
        mem[offset + i].level1 = 0;
        mem[offset + i].duration1 = 58;
    }
}

// ─── ISR ─────────────────────────────────────────────────────────────────────

static void IRAM_ATTR rmt_isr_handler(void *arg) {
    rmt_dev_t *dev = &RMT;
    uint32_t status = dev->int_st.val;

    // TX threshold reached (halfway point) → refill first half
    if (status & RMT_LL_EVENT_TX_THRES(RMT_TX_CHANNEL)) {
        rmt_ll_clear_interrupt_status(dev, RMT_LL_EVENT_TX_THRES(RMT_TX_CHANNEL));
        // HW is reading the second half → safe to write the first half
        fill_rmt_items(0, RMT_HALF_ITEMS);
    }

    // TX done (full wrap completed in conti mode) → refill second half
    if (status & RMT_LL_EVENT_TX_DONE(RMT_TX_CHANNEL)) {
        rmt_ll_clear_interrupt_status(dev, RMT_LL_EVENT_TX_DONE(RMT_TX_CHANNEL));
        // HW just wrapped back to start, reading the first half → safe to write second half
        fill_rmt_items(RMT_HALF_ITEMS, RMT_HALF_ITEMS);
    }

    // Clear any error
    if (status & RMT_LL_EVENT_TX_ERROR(RMT_TX_CHANNEL)) {
        rmt_ll_clear_interrupt_status(dev, RMT_LL_EVENT_TX_ERROR(RMT_TX_CHANNEL));
        ESP_EARLY_LOGW(TAG, "RMT TX error");
    }
}

// ─── Setup ───────────────────────────────────────────────────────────────────

void rmt_continuous_tx_start() {
    rmt_dev_t *dev = &RMT;

    // 1. Enable peripheral clock & memory
    rmt_ll_enable_periph_clock(dev, true);
    rmt_ll_power_down_mem(dev, false);
    rmt_ll_enable_mem_access_nonfifo(dev, true);

    // 2. Configure GPIO (same approach as ESP-IDF legacy RMT driver)
    gpio_hal_iomux_func_sel(GPIO_PIN_MUX_REG[RMT_TX_GPIO], PIN_FUNC_GPIO);
    gpio_set_direction(RMT_TX_GPIO, GPIO_MODE_OUTPUT);
    esp_rom_gpio_connect_out_signal(RMT_TX_GPIO,
        rmt_periph_signals.groups[0].channels[RMT_TX_CHANNEL].tx_sig, false, false);

    // 3. Configure channel clock
    rmt_ll_set_group_clock_src(dev, RMT_TX_CHANNEL, RMT_CLK_SRC_APB, 0, 0, 0);
    rmt_ll_tx_set_channel_clock_div(dev, RMT_TX_CHANNEL, RMT_CLK_DIV);

    // 4. Configure memory blocks
    rmt_ll_tx_set_mem_blocks(dev, RMT_TX_CHANNEL, RMT_MEM_BLOCKS);

    // 5. Enable continuous (loop) mode + wrap
    rmt_ll_tx_enable_loop(dev, RMT_TX_CHANNEL, true);   // tx_conti_mode = 1
    rmt_ll_tx_enable_wrap(dev, RMT_TX_CHANNEL, true);   // mem_tx_wrap_en = 1

    // 6. Set idle level (output low when idle, though in conti mode it shouldn't idle)
    rmt_ll_tx_fix_idle_level(dev, RMT_TX_CHANNEL, 0, true);

    // 7. Set TX threshold to fire interrupt at halfway point
    rmt_ll_tx_set_limit(dev, RMT_TX_CHANNEL, RMT_HALF_ITEMS);

    // 8. Pre-fill entire buffer with initial data
    fill_rmt_items(0, RMT_TOTAL_ITEMS);

    // 9. Register ISR
    esp_intr_alloc(ETS_RMT_INTR_SOURCE, ESP_INTR_FLAG_IRAM | ESP_INTR_FLAG_LEVEL1,
                   rmt_isr_handler, nullptr, &s_intr_handle);

    // 10. Enable interrupts: TX_DONE + TX_THRES
    uint32_t int_mask = RMT_LL_EVENT_TX_DONE(RMT_TX_CHANNEL)
                      | RMT_LL_EVENT_TX_THRES(RMT_TX_CHANNEL);
    rmt_ll_enable_interrupt(dev, int_mask, true);
    rmt_ll_clear_interrupt_status(dev, int_mask);

    // 11. Reset read pointer and start TX
    rmt_ll_tx_reset_pointer(dev, RMT_TX_CHANNEL);
    rmt_ll_tx_start(dev, RMT_TX_CHANNEL);

    ESP_LOGI(TAG, "Continuous RMT TX started on GPIO %d, %d items buffer, ISR at %d",
             RMT_TX_GPIO, RMT_TOTAL_ITEMS, RMT_HALF_ITEMS);
}

void rmt_continuous_tx_stop() {
    rmt_dev_t *dev = &RMT;

    // Disable interrupts
    uint32_t int_mask = RMT_LL_EVENT_TX_DONE(RMT_TX_CHANNEL)
                      | RMT_LL_EVENT_TX_THRES(RMT_TX_CHANNEL)
                      | RMT_LL_EVENT_TX_ERROR(RMT_TX_CHANNEL);
    rmt_ll_enable_interrupt(dev, int_mask, false);

    // Disable loop mode (this will stop after current cycle)
    rmt_ll_tx_enable_loop(dev, RMT_TX_CHANNEL, false);

    // Free ISR
    if (s_intr_handle) {
        esp_intr_free(s_intr_handle);
        s_intr_handle = nullptr;
    }

    ESP_LOGI(TAG, "Continuous RMT TX stopped");
}

// ─── Usage ───────────────────────────────────────────────────────────────────
//
// void app_main() {
//     rmt_continuous_tx_start();
//     // ... application runs, ISR keeps the waveform flowing ...
//     // To change what's being transmitted, update fill_rmt_items() logic
//     // or use a shared ring buffer that fill_rmt_items() reads from.
//     vTaskDelay(pdMS_TO_TICKS(10000));
//     rmt_continuous_tx_stop();
// }
